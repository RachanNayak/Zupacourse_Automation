# Base URL of the Divyakala LMS app (sandbox)
BASE_URL=https://app.sandbox.lms.zupaloop.ai

# Admin account for smoke tests (Long Course creation)
ADMIN_EMAIL=rachan@zupaloop.com

# Login: password or manual OTP
# Option 1: Password (if your admin uses password login)
# ADMIN_PASSWORD=your-password

# Option 2: Manual OTP – test fills email and clicks Continue; you enter OTP in the browser,
# then the test clicks Verify after MANUAL_OTP_WAIT_SECONDS (default 90).
MANUAL_OTP=1
# MANUAL_OTP_WAIT_SECONDS=90

# Option 3: Automatic OTP from env (set before each run)
# TEST_OTP=123456

# Sign out any existing session before logging in as ADMIN_EMAIL (e.g. to switch to rachan@zupaloop.com)
# SIGN_OUT_FIRST=1
